# --- OpenRouter (OpenAI-compatible) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default models. Nano is used for thread classification + cluster labels,
# mini is used for per-bookmark summaries.
OPENROUTER_SUMMARY_MODEL=openai/gpt-5.4-mini
OPENROUTER_NANO_MODEL=openai/gpt-5.4-nano

# --- Embeddings (local, ONNX via fastembed) ---
# See https://huggingface.co/spaces/mteb/leaderboard for alternatives.
# fastembed downloads to ~/.cache/fastembed on first run.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Agglomerative clustering thresholds on cosine distance (0 = identical, 1 = orthogonal).
# Lower = tighter groups, more folders.
CLUSTER_PRIMARY_THRESHOLD=0.7
CLUSTER_SUB_THRESHOLD=0.45

# --- twitter-cli ---
# twitter-cli reads cookies from your browser automatically. Override if needed:
# TWITTER_AUTH_TOKEN=
# TWITTER_CT0=
# TWITTER_BROWSER=chrome
# TWITTER_PROXY=

# --- Output ---
NOTES_DIR=notes
MAX_BOOKMARKS=800
FETCH_TIMEOUT_SECS=20

# Set to 0 to keep bookmarks after rendering notes (default: 1 = unbookmark processed tweets).
UNBOOKMARK_AFTER_RENDER=1
